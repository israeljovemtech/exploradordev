{
  "expo": {
    "name": "testador-de-sensores",
    "slug": "testador-de-sensores",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Precisamos da camera para capturar evidencias da missao."
        }
      ],
      [
        "expo-notifications"
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#121212",
          "image": "./assets/splash.png",
          "imageWidth": 250
        }
      ]
    ]
  }
}
